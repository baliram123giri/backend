// Prisma schema file for Fastify Backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Feedback {
  id        String   @id @default(uuid())
  name      String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model DownloadLog {
  id         String   @id @default(uuid())
  name       String
  location   String?
  format     String
  templateId String?
  ipAddress  String?
  userAgent  String?
  orderId    String?
  errorMsg   String?  @db.Text
  createdAt  DateTime @default(now())

  order      Order?   @relation(fields: [orderId], references: [razorpayOrderId])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user") // "admin", "moderator", "user"
  status    String   @default("active") // "active", "suspended"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id                     String   @id @default(uuid())
  name                   String
  description            String?  @default("")
  defaultPrimary         String
  defaultSecondary       String
  defaultAccent          String
  defaultPadding         Int      @default(60)
  defaultYPadding        Int?
  defaultPaddingTop      Int?
  defaultPaddingRight    Int?
  defaultPaddingLeft     Int?
  defaultFontSize        Int?
  photoX                 Int      @default(390)
  photoY                 Int      @default(100)
  photoWidth             Int      @default(100)
  photoHeight            Int      @default(130)
  photoCornerRadius      Int      @default(8)
  photoShowBorder        Boolean? @default(true)
  frameType              String   @default("image") // "image", "svg", "gradient", "custom"
  frameUrlTemplate       String?
  frameBgType            String?  @default("solid")
  frameBgColor           String?
  frameBgGradientColors  String[]
  frameOuterInset        Int?
  frameOuterStrokeWidth  Int?
  frameOuterCornerRadius Int?
  frameInnerInset        Int?
  frameInnerStrokeWidth  Int?
  frameInnerCornerRadius Int?
  frameHasCornerCurves   Boolean?
  frameGradientColors    String[]
  frameComponentId       String?
  thumbnailUrl           String?
  previewPhotoUrl        String?
  rawInput               Json?
  bgConfig               Json?
  detailsLayout          String   @default("classic")
  titleShape             String   @default("simple")
  defaultHeadingAlign    String   @default("left")
  sectionHeadingShape    String   @default("simple")
  mantraSignPlacement    String   @default("both")
  mantraSignVertical     String   @default("top")
  language               String   @default("English")
  religion               String?  @default("General")
  gender                 String   @default("both")
  active                 Boolean  @default(true)
  // Pricing
  isPremium              Boolean  @default(false)
  isDefault              Boolean  @default(false)
  price                  Float?
  discountPrice          Float?
  currency               String   @default("INR")
  // Format-specific Pricing
  pdfPrice               Float?
  pdfDiscountPrice       Float?
  docxPrice              Float?
  docxDiscountPrice      Float?
  jpgPrice               Float?
  jpgDiscountPrice       Float?
  pngPrice               Float?
  pngDiscountPrice       Float?
  comboPrice             Float?
  comboDiscountPrice     Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Background {
  id        String   @id @default(uuid())
  name      String
  url       String
  createdAt DateTime @default(now())
}

model HeroSlide {
  id        String   @id @default(uuid())
  title     String?  @default("")
  imageUrl  String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id           String   @id @default(uuid())
  slug         String   @unique
  title        String
  description  String
  thumbnailUrl String?
  publishDate  String
  readTime     String
  category     String
  language     String   @default("English")
  author       String
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id                String   @id @default(uuid())
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  razorpaySignature String?
  amount            Float
  currency          String   @default("INR")
  status            String   // "pending", "paid", "failed"
  format            String   // "pdf", "docx", "jpg", "png", "combo"
  templateId        String
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  couponCode        String?
  discountApplied   Float?   @default(0)
  downloadStatus    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  referralCode      String?
  cookieId          String?
  localStorageId    String?
  downloadLogs      DownloadLog[]
}

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  discountType  String    // "percentage" or "fixed"
  discountValue Float
  active        Boolean   @default(true)
  isPublic      Boolean   @default(true)
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Sticker {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String   @default("Normal") // "Normal" or "Mantra"
  religion  String?  // Optional: "Hindu", "Muslim", "Sikh", "Jain", "Christian", "All" etc.
  createdAt DateTime @default(now())
}

model Mantra {
  id          String   @id @default(uuid())
  religion    String
  text        String
  nativeText  String?
  meaning     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReviewSettings {
  id               String   @id @default("global")
  googleEnabled    Boolean  @default(true)
  googleRating     Float    @default(4.9)
  googleCount      Int      @default(524)
  googleUrl        String   @default("https://share.google/T4eEjxMJkqDKaFWGN")
  trustpilotEnabled Boolean  @default(true)
  trustpilotRating Float    @default(4.8)
  trustpilotCount  Int      @default(320)
  trustpilotUrl    String   @default("https://www.trustpilot.com/review/biodata99.com")
  updatedAt        DateTime @updatedAt
}

model Affiliate {
  id                  String            @id @default(uuid())
  name                String
  email               String            @unique
  password            String
  status              String            @default("pending") // "pending", "approved", "rejected", "suspended"
  code                String            @unique // unique referral code like BG1025
  channelType         String?           // e.g. "Bloggers", "YouTubers", etc.
  channelUrl          String?
  upiId               String?
  bankAccountName     String?
  bankAccountNumber   String?
  bankIfsc            String?
  totalClicks         Int               @default(0)
  uniqueVisitors      Int               @default(0)
  commissionRate      Float             @default(10.0) // custom commission override (e.g. 10.0 for 10%)
  phone               String?
  tier                String?           @default("standard") // "standard", "gold", "platinum"
  adminNotes          String?           @db.Text
  passwordResetToken  String?           // secure random hex token for password reset
  passwordResetExpiry DateTime?         // token expiry (15 minutes from issue)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  clicks              ReferralClick[]
  commissions         Commission[]
  withdrawals         Withdrawal[]
}

model ReferralClick {
  id             String    @id @default(uuid())
  affiliateId    String
  affiliate      Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  code           String
  ipAddress      String?
  userAgent      String?
  cookieId       String?
  localStorageId String?
  createdAt      DateTime  @default(now())
}

model Commission {
  id               String      @id @default(uuid())
  affiliateId      String
  affiliate        Affiliate   @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  orderId          String?     @unique
  orderAmount      Float
  commissionAmount Float
  status           String      @default("pending") // "pending", "approved", "paid", "rejected"
  approvedAt       DateTime?
  paidAt           DateTime?
  withdrawalId     String?
  withdrawal       Withdrawal? @relation(fields: [withdrawalId], references: [id])
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Withdrawal {
  id             String       @id @default(uuid())
  affiliateId    String
  affiliate      Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount         Float
  status         String       @default("pending") // "pending", "paid", "rejected"
  paymentMethod  String       // "UPI" or "Bank Transfer"
  paymentDetails String       // UPI ID or Bank details
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  commissions    Commission[]
}
